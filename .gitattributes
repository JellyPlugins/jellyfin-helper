# Auto-detect text files and normalise line endings to LF on commit.
* text=auto eol=lf

# Explicitly declare file types that are always text.
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.props text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.htm text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.ruleset text eol=lf
*.editorconfig text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary files — do not touch.
*.png binary
*.gif binary
*.jpg binary
*.jpeg binary
*.ico binary
*.dll binary
*.exe binary
*.zip binary
*.nupkg binary